---
// agniai.store — home page
// Positions the brand around the LEAK, not the LEAD. (Per ICP research:
// owner-operators care more about plugging holes than pouring more in the top.)
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Agni AI Store — Stop bleeding bookings to voicemail"
  description="AI-powered customer lifecycle for vet clinics, chiropractors, physiotherapists, and HVAC operators. Missed-call rescue, AI receptionist, review automation, win-back. Toronto-based. Done-for-you."
>
  <!-- ─── Hero ─── -->
  <section class="ai-hero">
    <p class="ai-eyebrow">VET CLINICS · CHIROPRACTORS · PHYSIO · HVAC</p>
    <h1>Stop bleeding bookings to voicemail.</h1>
    <p class="ai-lead">
      Most clinics and shops in the GTA lose 25–60% of inbound calls every week.
      No-shows cost another $150–$300 a pop. And the 3,000 clients who haven't been in for a year?
      Sitting in your software, never reached out to.
    </p>
    <p class="ai-lead" style="font-weight:600;color:var(--tx);">
      We run the customer lifecycle for you. AI-powered, done-for-you, $1,497/mo to start.
    </p>
    <div class="ai-cta-row">
      <a class="ai-btn" href="/services/">See pricing →</a>
      <a class="ai-btn-ghost" href="/how-it-works/">How it works</a>
    </div>
  </section>

  <!-- ─── Vertical selector ─── -->
  <section class="ai-section-tight">
    <div class="ai-wrap">
      <p class="ai-eyebrow" style="text-align:center;">Pick your industry</p>
      <h2 style="text-align:center;margin-bottom:32px;">Built for the way YOU run your business.</h2>
      <div class="ai-vertical-strip">

        <a class="ai-vertical-card" href="/for-vets/">
          <div class="ai-vertical-card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="11" cy="4" r="2"/>
              <circle cx="18" cy="8" r="2"/>
              <circle cx="20" cy="16" r="2"/>
              <path d="M9 10c-2 0-3.5 1.5-4 4-.5 4 2 5 4 5 1.5 0 3-1 5-1s4 2 5 0c1-3-2-7-4-7-2-1-4-1-6-1z"/>
            </svg>
          </div>
          <h3>Vet clinics</h3>
          <p>Recall lapsed clients, catch after-hours calls, drown out the bad reviews. AVImark / Cornerstone / ezyVet integration.</p>
          <span class="ai-vertical-card-arrow">For vet clinics →</span>
        </a>

        <a class="ai-vertical-card" href="/for-chiros/">
          <div class="ai-vertical-card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
              <circle cx="12" cy="12" r="4"/>
            </svg>
          </div>
          <h3>Chiropractors &amp; Physio</h3>
          <p>Reactivate inactives, fix the 5-minute lead response, finish care plans. Jane App–native.</p>
          <span class="ai-vertical-card-arrow">For chiro / physio →</span>
        </a>

        <a class="ai-vertical-card" href="/for-hvac/">
          <div class="ai-vertical-card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 12h18M6 6h12M6 18h12"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </div>
          <h3>HVAC &amp; Home Services</h3>
          <p>Stop missing calls in season. Fill the spring/fall shoulder. Triple your service-agreement attach. ServiceTitan / Housecall Pro / Jobber–compatible.</p>
          <span class="ai-vertical-card-arrow">For HVAC →</span>
        </a>

      </div>
    </div>
  </section>

  <!-- ─── Why this exists ─── -->
  <section class="ai-section">
    <div class="ai-wrap ai-narrow" style="text-align:center;">
      <p class="ai-eyebrow">Why this exists</p>
      <h2>Birdeye and Podium do reviews. HighLevel agencies do funnels. <br>Nobody runs the whole lifecycle for you.</h2>
      <p class="ai-lead" style="margin-top:24px;">
        We do. One system that catches the missed call, sends the reminder, asks for the review,
        rebooks the lapsed client, and quietly recovers the bookings that used to fall through the cracks.
        Done for you, by people who've shipped this stack inside Series-A SaaS companies.
      </p>
    </div>
  </section>

  <!-- ─── Stats / proof bar ─── -->
  <section>
    <div class="ai-wrap">
      <div class="ai-stats-row">
        <div class="ai-stat"><strong>25–60%</strong><span>inbound calls missed</span></div>
        <div class="ai-stat"><strong>$2,000+</strong><span>LTV per recovered new client</span></div>
        <div class="ai-stat"><strong>38–50%</strong><span>no-shows reduced (SMS)</span></div>
        <div class="ai-stat"><strong>5×</strong><span>more reviews via SMS vs email</span></div>
      </div>
    </div>
  </section>

  <!-- ─── How it works (preview) ─── -->
  <section class="ai-section">
    <div class="ai-wrap">
      <p class="ai-eyebrow" style="text-align:center;">How it works</p>
      <h2 style="text-align:center;margin-bottom:32px;">Three weeks from "we should do this" to "running on autopilot."</h2>
      <div class="ai-grid-3">
        <div class="ai-card">
          <h3>1. Free audit call</h3>
          <p>30 minutes on Zoom. We walk your phone log, your software, your Google profile, your last 90 days of bookings. Hand back a one-page leak report. No pitch, no slides.</p>
        </div>
        <div class="ai-card">
          <h3>2. We build it for you</h3>
          <p>HighLevel snapshot cloned to your business, n8n flows wired to your existing CRM/PIMS/FSM, Twilio number live, AI receptionist trained on your services. 7–10 days end to end.</p>
        </div>
        <div class="ai-card">
          <h3>3. We run it for you</h3>
          <p>Monthly retainer covers ops, optimization, content, reporting. You see the dashboard. We do the work. Cancel any time after the first 90 days.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Bottom CTA ─── -->
  <section class="ai-section">
    <div class="ai-wrap ai-narrow" style="text-align:center;">
      <h2>30-minute audit. No deck. No pitch. Just diagnostics.</h2>
      <p class="ai-lead">We tell you what's leaking and what to fix first — even if you never hire us.</p>
      <div class="ai-cta-row">
        <a class="ai-btn" href="https://calendly.com/aman-shopagni" target="_blank" rel="noopener">Book the audit →</a>
        <a class="ai-btn-ghost" href="/services/">See pricing</a>
      </div>
    </div>
  </section>
</BaseLayout>
