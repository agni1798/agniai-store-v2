---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Contact — Book the free audit"
  description="Book a 30-minute free audit, send a message, or email hello@agniai.store directly. Toronto-based."
>
  <section class="ai-hero">
    <p class="ai-eyebrow">CONTACT</p>
    <h1>Two ways in.</h1>
    <p class="ai-lead">Pick whichever fits — both go to the same inbox.</p>
  </section>

  <section class="ai-section">
    <div class="ai-wrap" style="max-width:860px;">
      <div class="ai-grid-2">

        <div class="ai-card" style="text-align:center;padding:36px 28px;">
          <div style="width:56px;height:56px;color:var(--accent);margin:0 auto 16px;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="width:100%;height:100%;"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
          </div>
          <h3>Book the audit (recommended)</h3>
          <p style="margin-bottom:24px;">30-min Zoom. We screen-share your software, walk the leaks, hand you a one-page report.</p>
          <a class="ai-btn" href="https://calendly.com/aman-shopagni" target="_blank" rel="noopener">Open Calendly →</a>
        </div>

        <div class="ai-card" style="text-align:center;padding:36px 28px;">
          <div style="width:56px;height:56px;color:var(--accent);margin:0 auto 16px;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="width:100%;height:100%;"><path d="M3 8l9 6 9-6M3 8v10a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8M3 8l9-6 9 6"/></svg>
          </div>
          <h3>Send a message</h3>
          <p style="margin-bottom:24px;">Tell us what's broken in 2–3 sentences. We respond within 1 business day.</p>
          <a class="ai-btn-ghost" href="mailto:hello@agniai.store">hello@agniai.store</a>
        </div>

      </div>

      <div class="ai-card" style="margin-top:32px;padding:28px;text-align:center;">
        <h3 style="margin-bottom:12px;">Form (if you'd rather)</h3>
        <form id="contactForm" style="display:grid;gap:14px;max-width:520px;margin:0 auto;text-align:left;">
          <label style="display:flex;flex-direction:column;gap:6px;">
            <span style="font-size:12px;text-transform:uppercase;letter-spacing:0.08em;color:var(--tx-soft);font-weight:600;">Your name *</span>
            <input type="text" name="name" required style="background:var(--bg0);border:1px solid var(--border-strong);color:var(--tx);font-size:15px;padding:11px 13px;border-radius:8px;font-family:inherit;" />
          </label>
          <label style="display:flex;flex-direction:column;gap:6px;">
            <span style="font-size:12px;text-transform:uppercase;letter-spacing:0.08em;color:var(--tx-soft);font-weight:600;">Email *</span>
            <input type="email" name="email" required style="background:var(--bg0);border:1px solid var(--border-strong);color:var(--tx);font-size:15px;padding:11px 13px;border-radius:8px;font-family:inherit;" />
          </label>
          <label style="display:flex;flex-direction:column;gap:6px;">
            <span style="font-size:12px;text-transform:uppercase;letter-spacing:0.08em;color:var(--tx-soft);font-weight:600;">Business name</span>
            <input type="text" name="company" style="background:var(--bg0);border:1px solid var(--border-strong);color:var(--tx);font-size:15px;padding:11px 13px;border-radius:8px;font-family:inherit;" />
          </label>
          <label style="display:flex;flex-direction:column;gap:6px;">
            <span style="font-size:12px;text-transform:uppercase;letter-spacing:0.08em;color:var(--tx-soft);font-weight:600;">Industry</span>
            <select name="industry" style="background:var(--bg0);border:1px solid var(--border-strong);color:var(--tx);font-size:15px;padding:11px 13px;border-radius:8px;font-family:inherit;">
              <option>Vet clinic</option>
              <option>Chiropractor</option>
              <option>Physiotherapist</option>
              <option>RMT / massage</option>
              <option>HVAC / plumbing / home services</option>
              <option>Other local services</option>
            </select>
          </label>
          <label style="display:flex;flex-direction:column;gap:6px;">
            <span style="font-size:12px;text-transform:uppercase;letter-spacing:0.08em;color:var(--tx-soft);font-weight:600;">What's broken (2–3 sentences)</span>
            <textarea name="problem" rows="4" style="background:var(--bg0);border:1px solid var(--border-strong);color:var(--tx);font-size:15px;padding:11px 13px;border-radius:8px;font-family:inherit;resize:vertical;"></textarea>
          </label>
          <input type="hidden" name="source" value="agniai.store-v2" />
          <button type="submit" class="ai-btn" style="margin-top:8px;">Send message →</button>
          <p id="contactStatus" style="font-size:13px;color:var(--tx-soft);margin:0;text-align:center;"></p>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  // Posts to shopagni.com /api/contact (the existing Cloudflare Worker)
  // Cross-origin POST works because the worker has CORS open for our domains.
  document.getElementById('contactForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target;
    const status = document.getElementById('contactStatus');
    const btn = form.querySelector('button[type=submit]');
    btn.disabled = true;
    btn.textContent = 'Sending…';
    try {
      const res = await fetch('https://shopagni.com/api/contact', {
        method: 'POST',
        body: new FormData(form),
      });
      if (!res.ok) throw new Error('failed');
      form.reset();
      status.textContent = '✓ Got it. We\'ll be in touch within 1 business day.';
      status.style.color = '#10b981';
    } catch (err) {
      status.textContent = 'Something went wrong. Email hello@agniai.store directly.';
      status.style.color = '#f97316';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Send message →';
    }
  });
</script>
