---
// agniai.store v2 base layout — Phase 5 repositioning (2026-05-04)
// Endorsed sub-brand of Agni Consulting. North America first, globally aspirational.
// Industry-flexible. Audit-first sales motion. Indigo identity, distinct from shopagni.com blue.

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  canonical?: string;
}

const {
  title,
  description = 'The AI customer lifecycle for owner-operated service businesses. Catch the missed call. Recover the lapsed client. Finish the care plan. Feed the review pipeline. Done-for-you, by operators. A service of Agni Consulting.',
  ogImage = '/og-default.png',
  noindex = false,
  canonical,
} = Astro.props;

const siteName = 'Agni AI Store';
const fullTitle = title.includes('Agni') ? title : `${title} | ${siteName}`;
const url = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={url} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:site_name" content={siteName} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Inter font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" />

    <!-- Stylesheet -->
    <link rel="stylesheet" href="/styles/global.css" />

    <!-- JSON-LD: Organization with parentOrganization endorsement -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      '@id': 'https://agniai.store/#organization',
      name: 'Agni AI Store',
      alternateName: 'Agni AI · Customer Lifecycle for Service Businesses',
      url: 'https://agniai.store',
      description: 'The AI customer lifecycle for owner-operated service businesses. Done-for-you. A service of Agni Consulting.',
      email: 'hello@agniai.store',
      areaServed: ['Canada', 'United States', 'North America'],
      parentOrganization: {
        '@type': 'Organization',
        '@id': 'https://shopagni.com/#organization',
        name: 'Agni Consulting',
        url: 'https://shopagni.com',
      },
      sameAs: ['https://shopagni.com'],
    })} />
  </head>
  <body>
    <header class="ai-site-header">
      <nav class="ai-nav" aria-label="Primary">
        <a class="ai-brand-logo" href="/">
          <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" fill="none" aria-hidden="true">
            <defs>
              <linearGradient id="aiFlame" x1="0%" y1="0%" x2="0%" y2="100%">
                <stop offset="0%" stop-color="#a5b4fc"/>
                <stop offset="60%" stop-color="#6366f1"/>
                <stop offset="100%" stop-color="#4338ca"/>
              </linearGradient>
            </defs>
            <path d="M16 4 C 22 12 26 18 26 22 a 10 10 0 0 1 -20 0 c 0 -4 4 -10 10 -18 z" fill="url(#aiFlame)" />
            <path d="M16 14 c 2 3 4 6 4 8 a 4 4 0 0 1 -8 0 c 0 -2 2 -5 4 -8 z" fill="#ffffff" fill-opacity="0.55" />
          </svg>
          <span class="ai-brand-mark">
            <span class="ai-brand-name">Agni<span style="color:#6366f1;">AI</span>.store</span>
            <span class="ai-brand-sub">An Agni Consulting service</span>
          </span>
        </a>
        <ul class="ai-nav-links">
          <li><a href="/industries/">Industries</a></li>
          <li><a href="/engagements/">Engagements</a></li>
          <li><a href="/case-studies/">Case studies</a></li>
          <li><a href="/about/">About</a></li>
          <li><a class="ai-nav-cta" href="/contact/">Free audit →</a></li>
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="ai-site-footer">
      <div class="ai-footer-inner">
        <div class="ai-footer-brand">
          <a class="ai-brand-logo" href="/">
            <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" fill="none" aria-hidden="true">
              <defs>
                <linearGradient id="aiFlameFooter" x1="0%" y1="0%" x2="0%" y2="100%">
                  <stop offset="0%" stop-color="#a5b4fc"/>
                  <stop offset="60%" stop-color="#6366f1"/>
                  <stop offset="100%" stop-color="#4338ca"/>
                </linearGradient>
              </defs>
              <path d="M16 4 C 22 12 26 18 26 22 a 10 10 0 0 1 -20 0 c 0 -4 4 -10 10 -18 z" fill="url(#aiFlameFooter)" />
              <path d="M16 14 c 2 3 4 6 4 8 a 4 4 0 0 1 -8 0 c 0 -2 2 -5 4 -8 z" fill="#ffffff" fill-opacity="0.55" />
            </svg>
            <span>Agni<span style="color:#6366f1;">AI</span>.store</span>
          </a>
          <p>The AI customer lifecycle for owner-operated service businesses. A service of <a href="https://shopagni.com" target="_blank" rel="noopener" style="color:var(--accent);text-decoration:underline;">Agni Consulting</a> — a B2B marketing-ops practice. Built by operators who&rsquo;ve shipped this stack inside Series-A and Series-B SaaS.</p>
        </div>
        <div class="ai-footer-cols">
          <div class="ai-footer-col">
            <h4>Industries</h4>
            <ul>
              <li><a href="/for-vets/">Vet clinics</a></li>
              <li><a href="/for-chiros/">Chiro &amp; physio</a></li>
              <li><a href="/for-dental/">Dental</a></li>
              <li><a href="/for-medspa/">Med-spa &amp; aesthetic</a></li>
              <li><a href="/for-hvac/">HVAC &amp; home services</a></li>
              <li><a href="/industries/">All industries</a></li>
            </ul>
          </div>
          <div class="ai-footer-col">
            <h4>Company</h4>
            <ul>
              <li><a href="/engagements/">Engagements</a></li>
              <li><a href="/case-studies/">Case studies</a></li>
              <li><a href="/how-it-works/">How it works</a></li>
              <li><a href="/about/">About</a></li>
              <li><a href="/trust/">Trust &amp; compliance</a></li>
              <li><a href="/contact/">Contact</a></li>
            </ul>
          </div>
          <div class="ai-footer-col">
            <h4>Parent</h4>
            <ul>
              <li><a href="https://shopagni.com" target="_blank" rel="noopener">Agni Consulting</a></li>
              <li><a href="https://shopagni.com/services-cart/" target="_blank" rel="noopener">B2B services catalogue</a></li>
              <li><a href="https://shopagni.com/insights/" target="_blank" rel="noopener">Insights</a></li>
              <li><a href="https://shopagni.com/about/" target="_blank" rel="noopener">About Agni</a></li>
            </ul>
          </div>
        </div>
      </div>
      <div class="ai-footer-bottom">
        <span>&copy; {new Date().getFullYear()} Agni Consulting · Toronto, Canada · Serving Canada &amp; the United States</span>
        <span>
          <a href="/privacy/">Privacy</a> &nbsp;·&nbsp;
          <a href="/terms/">Terms</a> &nbsp;·&nbsp;
          <a href="/trust/">Trust</a> &nbsp;·&nbsp;
          <a href="mailto:hello@agniai.store">hello@agniai.store</a>
        </span>
      </div>
    </footer>
  </body>
</html>
